{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Write(~/.dotfiles/)",
      "Edit(~/.dotfiles/)",
      "Write(~/.claude/skills/)",
      "Edit(~/.claude/skills/)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(brew *)",
      "Bash(mise *)",
      "Bash(stow *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(pnpx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(go *)",
      "Bash(ruby *)",
      "Bash(docker *)",
      "Bash(bash \"$HOME/.claude/skills/:*)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:docs.docker.com)"
    ],
    "additionalDirectories": [
      "~/.dotfiles",
      "~/.claude"
    ]
  },
  "model": "sonnet",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "modern-go-guidelines@goland-claude-marketplace": true
  },
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
